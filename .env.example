# ─────────────────────────────────────────────────────────────────────────────
# InvoxAI — environment. Copy to `.env` (gitignored) and fill in real values.
# A single root .env is loaded by every app (via next.config) and by Prisma CLI.
# NEVER commit real values. The service-role key must NEVER reach the browser.
# ─────────────────────────────────────────────────────────────────────────────

# --- Supabase Postgres (via Prisma) ---
# Pooled connection (PgBouncer, port 6543) — used by Prisma Client at RUNTIME.
DATABASE_URL="postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (port 5432) — used by Prisma CLI for MIGRATIONS only.
# Migrations hang on the pooler; they must use this direct URL.
DIRECT_URL="postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres"

# --- Supabase Auth / Storage ---
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
# anon key is safe for the browser (RLS enforces access).
NEXT_PUBLIC_SUPABASE_ANON_KEY="<supabase-anon-key>"
# service-role key bypasses RLS — SERVER ONLY. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY="<supabase-service-role-key>"

# --- Redis (same VPS) ---
REDIS_URL="redis://127.0.0.1:6379"

# Route sale notifications through the BullMQ worker instead of running them
# inline. Leave OFF (unset/false) until the worker is installed — see
# infra/WORKER.md. When "true", the tenant app enqueues and the invox-worker
# service processes the queue (falls back to inline if the enqueue fails).
NOTIFICATIONS_USE_QUEUE="false"

# --- Anthropic (AI builder — used from C9, optional before then) ---
ANTHROPIC_API_KEY=""

# --- Platform admin (C3) ---
# Comma-separated emails allowed into the admin app (admin.invoxai.io). These
# users still sign in via Supabase like anyone else; this allowlist is the
# authorization gate. Matched case-insensitively. SERVER ONLY (never NEXT_PUBLIC).
ADMIN_EMAILS="you@example.com"

# --- GST tax invoices (Phase 1.3) — InvoxAI's own income ---
# Fill with your CA-confirmed legal entity + GSTIN. Until GSTIN is set, invoices
# render as a non-tax DRAFT. GST rate in basis points (1800 = 18%).
INVOICE_LEGAL_NAME="InvoxAI"
INVOICE_GSTIN=""
INVOICE_ADDRESS=""
INVOICE_GST_RATE_BPS="1800"

# --- Monitoring (Phase 1.4) ---
# Sentry DSN for server-side error reporting (optional; apps no-op without it).
SENTRY_DSN=""
# Optional webhook (e.g. Slack incoming webhook) the monitor cron posts alerts to.
ALERT_WEBHOOK_URL=""

# --- Platform Razorpay gateway (C4) ---
# InvoxAI's OWN Razorpay account — collects InvoxAI's subscription + AI-page fees
# from sellers. NEVER used for buyer→seller payments (those go to each seller's
# own gateway, C6). Use TEST keys (rzp_test_…) in non-prod.
# KEY_ID is exposed to the browser for Checkout; SECRET + WEBHOOK_SECRET are
# server-only. Set WEBHOOK_SECRET to the same value configured on the Razorpay
# dashboard webhook (events: order.paid / payment.captured).
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="<razorpay-key-secret>"
RAZORPAY_WEBHOOK_SECRET="<razorpay-webhook-secret>"

# --- Seller gateway secret encryption (C6) ---
# Encrypts each seller's OWN Razorpay key secret at rest (AES-256-GCM).
# Generate with: openssl rand -base64 32   — SERVER ONLY, never commit the real key.
# Rotating this invalidates stored ciphertexts (requires a re-encrypt migration).
GATEWAY_ENCRYPTION_KEY="<base64-32-bytes>"

# --- Email channel (Phase 14) ---
# Resend API key enables real email (buyer receipts, seller sale alerts). When
# empty, sendEmail() is a logged no-op (notification_logs status "skipped") so
# nothing breaks. EMAIL_FROM must be a Resend-verified sender on a domain you own.
RESEND_API_KEY=""
EMAIL_FROM="InvoxAI <noreply@invoxai.io>"
