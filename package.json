{
  "name": "invoxai",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "prisma": "dotenv -e .env -- pnpm --filter @invoxai/db exec prisma",
    "db:generate": "pnpm --filter @invoxai/db exec prisma generate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @invoxai/db exec prisma migrate dev",
    "db:studio": "dotenv -e .env -- pnpm --filter @invoxai/db exec prisma studio"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
