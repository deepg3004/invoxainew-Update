// InvoxAI database schema.
//
// Runtime (Prisma Client) connects via the pooled DATABASE_URL (PgBouncer,
// port 6543). Migrations (Prisma CLI) use the direct DIRECT_URL (port 5432) —
// migrations hang on the pooler, so `directUrl` is required here.
//
// IMPORTANT (security): Prisma connects as the Postgres owner role and so
// BYPASSES Row Level Security. Tenant isolation is therefore enforced in
// application code (every tenant query scoped by ownerId/tenantId). RLS is
// enabled on every table as defense-in-depth for the Supabase anon/browser
// path. See the RLS migration that accompanies these models.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// App-level mirror of a Supabase Auth user (id == auth.users.id).
/// Created on first sign-in. A seller owns exactly one Tenant (C2); buyers
/// (C8) will also be Profiles but scoped per-tenant via a separate relation.
model Profile {
  id        String   @id @db.Uuid // = auth.users.id
  email     String?
  fullName  String?  @map("full_name")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// The tenant this profile owns as a seller (nullable until onboarding).
  ownedTenant Tenant?
  /// The tenants this profile is a BUYER on (C8), one per tenant.
  buyerAccounts BuyerAccount[]

  @@map("profiles")
}

/// A seller's site: username.invoxai.io. One tenant per owner for the MVP
/// (ownerId is unique). `username` is the subdomain label and is globally unique.
model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  username  String   @unique // lowercase subdomain label, validated app-side
  name      String?
  // GST place-of-supply: the seller's 2-digit state code (e.g. "19" = West
  // Bengal). Drives IGST vs CGST+SGST on the platform invoices billed to them.
  stateCode String?  @map("state_code")
  // Storefront announcement bar (optional): a short promo message shown across the
  // seller's storefront, with an optional link. Blank = no bar.
  announcement     String? @map("announcement")
  announcementLink String? @map("announcement_link")
  // Storefront branding (audit batch 1): logo + hero banner + brand accent colour,
  // an About-the-seller blurb, footer policy links, and store-level SEO overrides.
  // All optional; URLs/colours are sanitized at render.
  logoUrl              String? @map("logo_url")
  bannerUrl            String? @map("banner_url")
  brandColor           String? @map("brand_color")
  aboutText            String? @map("about_text")
  // Premium theme system: the storefront's chosen theme preset slug (one of the 24
  // in THEME_LIBRARY). Null = default. Paints /store + the commerce pages.
  storeTheme           String? @map("store_theme")
  privacyUrl           String? @map("privacy_url")
  refundUrl            String? @map("refund_url")
  termsUrl             String? @map("terms_url")
  storeMetaTitle       String? @map("store_meta_title")
  storeMetaDescription String? @map("store_meta_description")
  // Phase 3 admin: when set, the storefront + checkout are blocked (suspended).
  suspendedAt DateTime? @map("suspended_at")
  // Phase 16: seller verification (trust badge). Seller submits details → PENDING;
  // admin approves (VERIFIED, badge on storefront) or rejects. Denormalised here so
  // the storefront badge needs no extra query (tenant is already host-resolved).
  verificationStatus      VerificationStatus @default(UNVERIFIED) @map("verification_status")
  verificationNote        String?            @map("verification_note") // seller's submission
  verificationReviewNote  String?            @map("verification_review_note") // admin note
  verificationSubmittedAt DateTime?          @map("verification_submitted_at")
  verifiedAt              DateTime?          @map("verified_at")
  ownerId   String   @unique @db.Uuid
  owner     Profile  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([username])
  @@map("tenants")

  // C4: a tenant has at most one platform subscription, and many checkout orders.
  subscription Subscription?
  orders       PlatformOrder[]
  // C5: a tenant has at most one prepaid wallet (for InvoxAI fees only).
  wallet       Wallet?
  // C6: a tenant connects at most one of their OWN payment gateways (buyer money
  // settles here, seller-direct — never through InvoxAI).
  gateway      SellerGateway?
  // C7: a tenant has many payment pages and buyer payments.
  paymentPages PaymentPage[]
  buyerPayments BuyerPayment[]
  // C8: the buyers who have an account on this tenant's site.
  buyerAccounts BuyerAccount[]
  // C9: AI-generated landing pages on the tenant's site.
  aiPages      AiPage[]
  // Ads tracking: per-tenant pixel/measurement IDs injected on public pages.
  tracking     TenantTracking?
  // Store: the seller's product catalog (Final Plan §9).
  products     Product[]
  collections  Collection[]
  // Store slice 3 (coupons): the seller's discount codes.
  coupons      Coupon[]
  affiliates   Affiliate[]
  // Growth G1.1: post-purchase one-time offers (OTO).
  upsells      Upsell[]
  // Growth G1.3: email/DM drip sequences.
  emailSequences EmailSequence[]
  // Phase 14: one-off email broadcasts to contact segments.
  broadcasts     Broadcast[]
  // Growth G1.6: A/B tests on payment pages.
  pageExperiments PageExperiment[]
  // Ops: buyer support tickets.
  supportTickets  SupportTicket[]
  // Builder: multi-page sites grouping AI pages.
  builderSites    BuilderSite[]
  // Courses / LMS (Final Plan §10): the seller's courses + buyer enrolments.
  courses      Course[]
  enrolments   Enrolment[]
  // Course-completion certificates issued to this tenant's learners.
  certificates Certificate[]
  // Notifications (Final Plan §28): the seller's in-app notifications.
  notifications Notification[]
  // Custom domains (Final Plan §38): the seller's connected domains.
  domains       TenantDomain[]
  // Phase 16: abuse/scam reports filed against this store.
  abuseReports  AbuseReport[]
  // Phase 16: admin-facing risk signals about this store.
  riskAlerts    RiskAlert[]
  // Phase: live workshops + their registrations.
  workshops             Workshop[]
  workshopRegistrations WorkshopRegistration[]
  // Phase: 1-on-1 booking offerings + their bookings.
  bookingTypes          BookingType[]
  bookings              Booking[]
  // Phase: media library (cloud storage) assets.
  fileAssets            FileAsset[]
  // Phase 12: communities (members spaces) + their memberships.
  communities          Community[]
  communityMemberships CommunityMembership[]
  communityMessages    CommunityMessage[]
  kycDocuments         KycDocument[]
  // Lead forms + CRM (Final Plan §12): capture forms and their submissions.
  leadForms     LeadForm[]
  leadSubmissions LeadSubmission[]
  // Bio link (Final Plan §12): one link-in-bio page per tenant.
  bioLink       BioLink?
  bioLinkClicks BioLinkClick[]
}

/// A click on a bio-link button/social (append-only analytics). Recorded by the
/// /bio/r redirect, which only records targets that are in the tenant's own
/// published bio. RLS: deny-anon; read tenant-scoped (seller stats).
model BioLinkClick {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  targetUrl String   @map("target_url")
  label     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@map("bio_link_clicks")
}

/// Link-in-bio page for a tenant (Final Plan §12) — a single public page that
/// aggregates the seller's socials and links. One per tenant. Social/link URLs
/// are sanitized with safeUrl at render (no javascript:/data: URLs). RLS:
/// deny-anon; the public read goes through Prisma server-side.
model BioLink {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @unique @map("tenant_id") @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  displayName String?  @map("display_name")
  bio         String?
  avatarUrl   String?  @map("avatar_url")
  instagram   String?
  youtube     String?
  twitter     String?
  facebook    String?
  whatsapp    String?
  website     String?
  tiktok      String?
  linkedin    String?
  threads     String?
  // Optional background colour (hex) for the public bio page; validated at render.
  bgColor     String?  @map("bg_color")
  // Custom links as "Label | https://url" lines; parsed + sanitized at render.
  linksText   String?  @map("links_text")
  published   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("bio_links")
}

/// Lead-capture form on a tenant's public site (Final Plan §12). v1 collects a
/// fixed set of fields (name/email/phone/message); the seller controls title,
/// description, button label and which optional fields show. RLS: deny-anon —
/// reads/writes are server-side, always tenant-scoped.
model LeadForm {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String           @map("tenant_id") @db.Uuid
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slug        String
  title       String
  description String?
  buttonLabel String           @default("Submit") @map("button_label")
  successMessage String?       @map("success_message")
  collectPhone   Boolean       @default(true) @map("collect_phone")
  collectMessage Boolean       @default(true) @map("collect_message")
  // Audit batch 4: notify the seller on each submission, and optionally redirect
  // the visitor to a thank-you / product URL after submitting.
  notifyOnSubmit Boolean       @default(true) @map("notify_on_submit")
  redirectUrl    String?       @map("redirect_url")
  status      LeadFormStatus   @default(DRAFT)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  submissions LeadSubmission[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@map("lead_forms")
}

enum LeadFormStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// A single submission of a LeadForm (Final Plan §12 / CRM). Buyer PII — always
/// read tenant-scoped (a seller sees only their own). RLS: deny-anon.
model LeadSubmission {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  formId    String   @map("form_id") @db.Uuid
  form      LeadForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  name      String?
  email     String?
  phone     String?
  message   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([formId, createdAt])
  @@map("lead_submissions")
}

/// Per-tenant ads/analytics tracking IDs (Final Plan §21). Injected on the
/// seller's public pages so their PageView/Purchase events flow to Meta/Google.
/// All optional; blank fields inject nothing. RLS: deny-anon (read server-side).
model TenantTracking {
  tenantId         String   @id @map("tenant_id") @db.Uuid
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  metaPixelId      String?  @map("meta_pixel_id")
  ga4MeasurementId String?  @map("ga4_measurement_id")
  googleAdsId      String?  @map("google_ads_id")
  gtmId            String?  @map("gtm_id")
  tiktokPixelId    String?  @map("tiktok_pixel_id")
  // Growth G1.5: show live "someone just bought …" social-proof popups on the
  // seller's public pages (derived from recent PAID orders, masked — no PII). On by
  // default; the seller can switch it off here.
  socialProofEnabled Boolean @default(true) @map("social_proof_enabled")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("tenant_tracking")
}

/// A sellable product in a tenant's store (Final Plan §9, slice 1 = catalog).
/// Buyers will pay for these on the SELLER's own gateway (slice 2 storefront +
/// checkout), so this carries no buyer money — it's just the catalog. Price is
/// integer paise. `stockQty` null = unlimited; a number is units remaining
/// (decremented on sale in slice 2). RLS: published rows are read server-side
/// to render the storefront; writes are seller-only via Prisma (deny-anon).
model Product {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @map("tenant_id") @db.Uuid
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slug        String
  title       String
  description String?
  pricePaise  Int           @map("price_paise")
  // Optional "compare-at" / original price for a sale. When set ABOVE pricePaise,
  // the storefront shows it struck through + a % off. Display only — buyers are
  // always charged pricePaise (the actual price).
  compareAtPaise Int?       @map("compare_at_paise")
  // Order bump: when true this product is offered as a one-tap add-on at checkout
  // (product pages + cart). The store's first bump-enabled product is THE bump.
  bumpEnabled Boolean       @default(false) @map("bump_enabled")
  bumpBlurb   String?       @map("bump_blurb") // short pitch shown on the bump card
  imageUrl    String?       @map("image_url")
  // Audit batch 3: extra gallery images, free-form tags, and per-product SEO.
  galleryUrls     String[]  @map("gallery_urls") // additional images beyond imageUrl
  tags            String[]                       // free-form labels for filtering
  metaTitle       String?   @map("meta_title")
  metaDescription String?   @map("meta_description")
  kind        ProductKind   @default(DIGITAL)
  // Optional storefront collection/category grouping (Shopify-style). Null = none.
  collectionId String?      @map("collection_id") @db.Uuid
  collection   Collection?  @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  // Gated post-purchase access link (community invite / download URL). Revealed
  // to the buyer ONLY on a PAID order (getBuyerOrder) — never on public pages.
  accessUrl   String?       @map("access_url")
  // Hosted digital download: the PRIVATE storage object key + original filename.
  // Delivered to the buyer ONLY via a short-lived signed URL on a PAID order; the
  // key is never exposed on public pages.
  downloadKey  String?      @map("download_key")
  downloadName String?      @map("download_name")
  status      ProductStatus @default(DRAFT)
  stockQty    Int?          @map("stock_qty")
  sortOrder   Int           @default(0) @map("sort_order")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@index([collectionId])
  @@map("products")

  // Store slice 2: buyer orders placed against this product.
  buyerPayments BuyerPayment[]
  // Store slice 3: line items referencing this product (multi-item carts).
  orderItems    OrderItem[]
  // Verified-purchase reviews.
  reviews       ProductReview[]
  // Purchasable variations (size/color). Empty = the product has no variants.
  variants      ProductVariant[]
  // Growth G1.1: OTOs that PITCH this product, and OTOs gated on BUYING this product.
  offerUpsells   Upsell[] @relation("UpsellOffer")
  triggerUpsells Upsell[] @relation("UpsellTrigger")
  // Growth G1.3: PURCHASE sequences gated on buying this product.
  sequenceTriggers EmailSequence[]
}

/// A purchasable variation of a product (Shopify-style size/color), with its own
/// price + stock. When a product has variants, checkout MUST price the chosen
/// variant server-side (never the base product). RLS: deny-anon lockdown.
model ProductVariant {
  id         String   @id @default(uuid()) @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  label      String // e.g. "Large / Red"
  pricePaise Int      @map("price_paise")
  stockQty   Int?     @map("stock_qty") // null = unlimited
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@map("product_variants")
}

/// A buyer's star rating + review of a product. Written ONLY after a PAID order
/// containing the product (verified purchase, enforced in createProductReview),
/// one per buyer per product. `tenantId` is denormalised for tenant-scoped seller
/// moderation (scalar + FK in migration, like other aux tables). status HIDDEN
/// lets the seller moderate a review off the public page. deny-anon RLS.
model ProductReview {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @map("tenant_id") @db.Uuid
  // A review is for EITHER a product OR a course (exactly one set; enforced in the
  // app). Product reviews verify a PAID order; course reviews verify an enrolment.
  productId      String?      @map("product_id") @db.Uuid
  product        Product?     @relation(fields: [productId], references: [id], onDelete: Cascade)
  courseId       String?      @map("course_id") @db.Uuid
  course         Course?      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  buyerProfileId String       @map("buyer_profile_id") @db.Uuid
  authorName     String?      @map("author_name")
  rating         Int // 1..5
  body           String?
  status         ReviewStatus @default(PUBLISHED)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@unique([productId, buyerProfileId])
  @@unique([courseId, buyerProfileId])
  @@index([productId, status])
  @@index([courseId, status])
  @@index([tenantId, createdAt])
  @@map("product_reviews")
}

enum ReviewStatus {
  PUBLISHED
  HIDDEN
}

enum ProductKind {
  DIGITAL
  PHYSICAL
  SERVICE
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// How a coupon's `value` is interpreted (Store slice 3 coupons).
/// PERCENT → `value` is basis points off the subtotal (1000 = 10%).
/// FLAT → `value` is paise off the subtotal.
enum DiscountType {
  PERCENT
  FLAT
}

/// A seller's discount code (Store slice 3 coupons). `code` is stored UPPERCASE
/// and is unique per tenant. The discount is always applied SERVER-TRUSTED at
/// checkout (see applyCoupon): a percent/flat amount, clamped so an order is
/// never free or negative. `redeemedCount` is incremented only by the PAID claim
/// winner in markBuyerPaymentPaid (idempotent — a replayed webhook can't
/// double-count). `maxRedemptions` null = unlimited; `startsAt`/`expiresAt` null
/// = open-ended. Carries no buyer money — it only reduces the seller's sale total
/// (and therefore InvoxAI's commission on it). RLS: deny-anon lockdown.
model Coupon {
  id               String       @id @default(uuid()) @db.Uuid
  tenantId         String       @map("tenant_id") @db.Uuid
  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code             String // stored UPPERCASE; unique per tenant
  type             DiscountType
  value            Int // PERCENT → bps; FLAT → paise
  minSubtotalPaise Int?         @map("min_subtotal_paise")
  maxRedemptions   Int?         @map("max_redemptions") // null = unlimited
  redeemedCount    Int          @default(0) @map("redeemed_count")
  // Audit batch 2 restrictions (all optional, enforced server-side in applyCoupon):
  perCustomerLimit Int?         @map("per_customer_limit") // max uses per buyer email; null = unlimited
  firstOrderOnly   Boolean      @default(false) @map("first_order_only") // only buyers with no prior PAID order
  productId        String?      @map("product_id") @db.Uuid // restrict to one product; null = whole store
  startsAt         DateTime?    @map("starts_at")
  expiresAt        DateTime?    @map("expires_at")
  isActive         Boolean      @default(true) @map("is_active")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  buyerPayments BuyerPayment[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([productId])
  @@map("coupons")
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// A sellable course (Courses / LMS, Final Plan §10, slice 1). A first-class
/// sellable (not a Product) because it has no stock/quantity and grants ongoing
/// access rather than shipping a unit. A buyer pays on the SELLER's gateway (same
/// rail as products — money settles seller-direct, commission from the seller's
/// wallet) and the PAID order grants an Enrolment. `slug` unique per tenant; the
/// public course page is `username.invoxai.io/c/<slug>`. RLS: deny-anon lockdown.
model Course {
  id          String       @id @default(uuid()) @db.Uuid
  tenantId    String       @map("tenant_id") @db.Uuid
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slug        String
  title       String
  subtitle    String?
  description String?
  // Udemy-style landing content (Phase: store/course redesign). Empty by default.
  learnPoints  String[]    @map("learn_points")
  requirements String[]
  pricePaise  Int          @map("price_paise")
  // Optional compare-at / original price for a sale (display only — buyers are
  // charged pricePaise). Shown struck through + a % off, like products.
  compareAtPaise Int?      @map("compare_at_paise")
  imageUrl    String?      @map("image_url")
  status      CourseStatus @default(DRAFT)
  sortOrder   Int          @default(0) @map("sort_order")
  // When on, a completion certificate is auto-issued once a learner finishes every
  // lesson (see issueCertificateIfEligible). Off by default.
  certificateEnabled Boolean @default(false) @map("certificate_enabled")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  lessons       Lesson[]
  sections      CourseSection[]
  enrolments    Enrolment[]
  buyerPayments BuyerPayment[]
  reviews       ProductReview[]
  certificates  Certificate[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@map("courses")
}

/// One lesson in a course's curriculum (slice 1 = text/markdown body; video +
/// signed URLs come in a later slice). `isPreview` lessons are viewable by anyone
/// on the public course page; the rest require an Enrolment. Ordered by
/// `sortOrder`. RLS: deny-anon lockdown — lesson bodies are served server-side
/// only after the enrolment check (preview lessons excepted).
model Lesson {
  id        String   @id @default(uuid()) @db.Uuid
  courseId  String   @map("course_id") @db.Uuid
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title     String
  content   String?  // text/markdown lesson body
  // Optional video lesson (YouTube/Vimeo link; embedded in the player). Plus an
  // optional duration for the curriculum/player UI.
  videoUrl    String? @map("video_url")
  durationSec Int?    @map("duration_sec")
  isPreview Boolean  @default(false) @map("is_preview")
  sortOrder Int      @default(0) @map("sort_order")
  // Optional module/section grouping (Udemy-style curriculum). Null = ungrouped.
  sectionId String?        @map("section_id") @db.Uuid
  section   CourseSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  progress  LessonProgress[]
  quiz      Quiz?

  @@index([courseId])
  @@map("lessons")
}

/// An optional multiple-choice quiz attached to a lesson (one per lesson). Buyers
/// take it on the learn page as a self-check; `passPercent` is the bar. NOT a money
/// path. tenantId is denormalised for scoped seller reads (cascade cleanup comes
/// via the lesson FK). RLS: deny-anon.
model Quiz {
  id          String         @id @default(uuid()) @db.Uuid
  tenantId    String         @map("tenant_id") @db.Uuid
  lessonId    String         @unique @map("lesson_id") @db.Uuid
  lesson      Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  passPercent Int            @default(70) @map("pass_percent")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  questions   QuizQuestion[]
  attempts    QuizAttempt[]

  @@index([tenantId])
  @@map("quizzes")
}

/// One question of a quiz. `options` are the choices (2–6); `correctIndex` points at
/// the right one — NEVER sent to the buyer (the learner read strips it). Ordered by
/// sortOrder.
model QuizQuestion {
  id           String   @id @default(uuid()) @db.Uuid
  quizId       String   @map("quiz_id") @db.Uuid
  quiz         Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  prompt       String
  options      String[]
  correctIndex Int      @map("correct_index")
  sortOrder    Int      @default(0) @map("sort_order")

  @@index([quizId, sortOrder])
  @@map("quiz_questions")
}

/// A buyer's graded attempt at a quiz (history; the best/last drives the UI badge).
model QuizAttempt {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  quizId         String   @map("quiz_id") @db.Uuid
  quiz           Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  buyerProfileId String   @map("buyer_profile_id") @db.Uuid
  scorePercent   Int      @map("score_percent")
  passed         Boolean
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([quizId, buyerProfileId])
  @@map("quiz_attempts")
}

/// A storefront collection/category grouping products (Shopify-style). Optional —
/// products may be uncategorised. Ordered by sortOrder.
model Collection {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title     String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  products  Product[]

  @@index([tenantId])
  @@map("collections")
}

/// A curriculum module/section grouping a course's lessons (Udemy-style).
/// Optional — lessons may be ungrouped. Ordered by sortOrder.
model CourseSection {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  courseId  String   @map("course_id") @db.Uuid
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title     String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  lessons   Lesson[]

  @@index([courseId])
  @@map("course_sections")
}

/// A buyer's completion of one lesson (Phase A: course progress). One row per
/// (lesson, buyer) — presence = completed. Buyer is the logged-in Profile
/// (the learn page requires login). tenantId/courseId denormalised for scoped reads.
model LessonProgress {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  courseId       String   @map("course_id") @db.Uuid
  lessonId       String   @map("lesson_id") @db.Uuid
  lesson         Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  buyerProfileId String   @map("buyer_profile_id") @db.Uuid
  completedAt    DateTime @default(now()) @map("completed_at")

  @@unique([lessonId, buyerProfileId])
  @@index([courseId, buyerProfileId])
  @@map("lesson_progress")
}

/// A course-completion certificate, auto-issued once a learner finishes every lesson
/// of a certificate-enabled course (issueCertificateIfEligible — idempotent on the
/// (course, buyer) unique). `serial` is an unguessable public code: anyone with the
/// link at /verify/<serial> can view + verify it (good for sharing on LinkedIn).
model Certificate {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId       String   @map("course_id") @db.Uuid
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  buyerProfileId String   @map("buyer_profile_id") @db.Uuid
  recipientName  String   @map("recipient_name")
  serial         String   @unique
  issuedAt       DateTime @default(now()) @map("issued_at")

  @@unique([courseId, buyerProfileId])
  @@index([tenantId])
  @@map("certificates")
}

/// A buyer's access grant to a course (Courses / LMS). Created ONLY by the PAID
/// claim winner in markBuyerPaymentPaid, keyed by `buyerPaymentId` (unique) so a
/// replayed webhook can't double-grant. The buyer is attributed by
/// `buyerProfileId` when logged in at checkout, else by `buyerEmail` (guest) —
/// mirroring BuyerPayment so a guest purchase grants access once the buyer signs
/// in with the same email. Always tenant-scoped. RLS: deny-anon lockdown.
model Enrolment {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId       String        @map("course_id") @db.Uuid
  course         Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  buyerProfileId String?       @map("buyer_profile_id") @db.Uuid
  buyerEmail     String?       @map("buyer_email")
  buyerPaymentId String?       @unique @map("buyer_payment_id") @db.Uuid
  buyerPayment   BuyerPayment? @relation(fields: [buyerPaymentId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now()) @map("created_at")

  @@index([tenantId, courseId])
  @@index([courseId, buyerProfileId])
  @@map("enrolments")
}

/// C4 subscription lifecycle. PENDING = order created, not yet paid; ACTIVE =
/// paid and within the period; PAST_DUE = period lapsed without renewal;
/// CANCELED = explicitly ended.
enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum OrderStatus {
  CREATED
  PAID
  FAILED
}

/// What a paid platform order does (C5 unifies the two money flows through one
/// idempotent paid-order path). SUBSCRIPTION extends the plan period;
/// WALLET_TOPUP credits the prepaid wallet.
enum OrderPurpose {
  SUBSCRIPTION
  WALLET_TOPUP
  FEATURE
}

/// Wallet ledger entry direction. CREDIT = money in (top-up); DEBIT = money out
/// (InvoxAI fee). Buyer money NEVER appears here (hard rule).
enum WalletTxnDirection {
  CREDIT
  DEBIT
}

/// Payment gateway a seller connects as their own (C6). Razorpay for the MVP.
enum GatewayProvider {
  RAZORPAY
}

/// Test vs live mode of the connected gateway, derived from the key id prefix
/// (rzp_test_… / rzp_live_…). Surfaced so sellers don't accidentally take real
/// buyer money on test keys (or vice-versa).
enum GatewayMode {
  TEST
  LIVE
}

enum GatewayStatus {
  CONNECTED
  DISCONNECTED
}

/// Lifecycle of a buyer payment (C7). CREATED = order made on the seller's
/// gateway, not yet paid; PAID = signature-verified success; FAILED = abandoned.
enum BuyerPaymentStatus {
  CREATED
  PENDING // manual UPI: buyer submitted a reference, awaiting seller confirmation
  PAID
  FAILED
  EXPIRED // manual UPI: payment session timed out before the buyer submitted a ref
  CANCELLED // manual UPI: was auto-confirmed PAID, then the seller reversed it ("not received")
}

/// How a buyer paid. RAZORPAY = seller's connected gateway (auto-verified via
/// signature). UPI_MANUAL = seller's UPI ID, buyer-submitted reference confirmed
/// by the seller. Either way the money goes buyer→seller direct (never InvoxAI).
enum PaymentMethod {
  RAZORPAY
  UPI_MANUAL
}

/// InvoxAI commission on a buyer payment (C7). PAID = debited from the seller's
/// wallet; DUE = wallet couldn't cover it, owed and settled on the next top-up.
/// Buyer money is never touched — commission only ever moves seller wallet money.
enum CommissionStatus {
  PAID
  DUE
}

/// A platform subscription tier a seller can subscribe to (used from C4).
///
/// MONEY: all amounts are stored as INTEGER paise (₹1 = 100 paise) — never
/// floats — to avoid rounding errors. Commission is stored as INTEGER basis
/// points (`commissionBps`): 250 = 2.50%, 10000 = 100%. Code references the
/// stable `key`, never the price, so admins can re-price without code changes
/// (hard rule: all pricing/limits/commission come from the DB, admin-editable).
///
/// Plans are never hard-deleted (a seller may be subscribed); `isActive=false`
/// retires a plan instead. RLS is enabled with NO policy → the anon/browser
/// path is denied entirely; only server code (Prisma, owner role) reads/writes.
model Plan {
  id            String   @id @default(uuid()) @db.Uuid
  key           String   @unique // stable slug referenced by code, e.g. "starter"
  name          String
  description   String?
  priceMonthly  Int      @default(0) @map("price_monthly") // paise
  priceYearly   Int      @default(0) @map("price_yearly") // paise
  commissionBps Int      @default(0) @map("commission_bps") // basis points
  maxProducts   Int?     @map("max_products") // null = unlimited
  maxAiPages    Int?     @map("max_ai_pages") // null = unlimited
  // Custom domains (Phase 15) are a premium feature; gated per plan.
  customDomainAllowed Boolean @default(false) @map("custom_domain_allowed")
  isActive      Boolean  @default(true) @map("is_active")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]
  orders        PlatformOrder[]
  featureLimits PlanFeatureLimit[]

  @@index([isActive, sortOrder])
  @@map("plans")
}

/// Admin-configurable paid feature (Feature Billing engine). `featureKey` is the
/// stable code handle (e.g. "ai_page"). Price is integer paise; GST in bps. Admin
/// toggles wallet/direct payment + active. Generalizes the AI-page ₹149 pattern.
model FeatureRule {
  featureKey    String   @id @map("feature_key")
  name          String
  basePaise     Int      @map("base_paise")
  gstRateBps    Int      @default(1800) @map("gst_rate_bps")
  walletEnabled Boolean  @default(true) @map("wallet_enabled")
  directEnabled Boolean  @default(false) @map("direct_enabled")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  limits PlanFeatureLimit[]

  @@map("feature_rules")
}

/// Per-plan free monthly allowance for a feature. `freeLimit` -1 = unlimited,
/// 0 = none free (always charged). Beyond the allowance the FeatureRule price
/// applies.
model PlanFeatureLimit {
  id         String      @id @default(uuid()) @db.Uuid
  planId     String      @map("plan_id") @db.Uuid
  plan       Plan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  featureKey String      @map("feature_key")
  rule       FeatureRule @relation(fields: [featureKey], references: [featureKey], onDelete: Cascade)
  freeLimit  Int         @default(0) @map("free_limit")

  @@unique([planId, featureKey])
  @@map("plan_feature_limits")
}

/// Per-tenant monthly usage counter for a feature (`period` = "YYYY-MM"). Drives
/// the free-allowance check.
model FeatureUsage {
  id         String @id @default(uuid()) @db.Uuid
  tenantId   String @map("tenant_id") @db.Uuid
  featureKey String @map("feature_key")
  period     String
  count      Int    @default(0)

  @@unique([tenantId, featureKey, period])
  @@index([tenantId])
  @@map("feature_usage")
}

/// Audit log of every PAID feature use (over the free allowance). The wallet
/// debit references the same `referenceId`. Only ever moves seller wallet money.
model FeatureCharge {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  featureKey  String   @map("feature_key")
  basePaise   Int      @map("base_paise")
  gstPaise    Int      @map("gst_paise")
  totalPaise  Int      @map("total_paise")
  payVia      String   @map("pay_via")
  referenceId String   @unique @map("reference_id")
  // For a direct-paid PREPAID credit (payVia="direct"): null = available, set =
  // already consumed by a feature use. Wallet charges leave this null (they are
  // consumed at the instant they're written, never a standing credit).
  consumedAt  DateTime? @map("consumed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@map("feature_charges")
}

/// Platform-wide pricing knobs as key/value, admin-editable (e.g. the
/// `ai_page_price` ₹149 fee). `valuePaise` is INTEGER paise, as above. Kept
/// separate from Plan because these are global, not per-tier. RLS: same
/// deny-anon lockdown as Plan.
model PricingSetting {
  key        String   @id // stable code key, e.g. "ai_page_price"
  label      String // human-readable description shown in the admin editor
  valuePaise Int      @map("value_paise")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("pricing_settings")
}

/// Global platform settings as string key/value — admin-managed config that used
/// to live in env (invoice legal name / GSTIN / address / GST rate) plus branding
/// (logo + favicon URLs). PLATFORM-GLOBAL, admin-only (after requireAdmin), same
/// deny-anon RLS lockdown as PricingSetting. NOT for secrets (keys/passwords) —
/// those stay in env, encrypted; this is plaintext, non-secret config only.
model PlatformSetting {
  key       String   @id // stable code key, e.g. "invoice_gstin"
  value     String // free-text value (URL, GSTIN, address, bps as string…)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

/// Public page-view events for a tenant's site (Phase 13 page-level analytics).
/// Append-only, recorded by a best-effort beacon on the public tenant pages.
/// No PII — path + referrer + a random session id (cookie) + optional utm source.
/// deny-anon RLS; reads are tenant-scoped for the seller's analytics.
model PageView {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  path      String
  referrer  String?
  sessionId String?  @map("session_id")
  source    String? // utm_source / campaign, if present
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@map("page_views")
}

/// Seller-facing activity log — important account events (gateway connected, page
/// published, refund issued, domain verified…). Append-only, written best-effort
/// after the action. deny-anon RLS; the seller reads only their own (tenant-scoped).
model ActivityLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  action    String // stable code, e.g. "gateway.connected"
  detail    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@map("activity_logs")
}

/// A seller's platform subscription (C4). Exactly one per tenant (`tenantId`
/// unique). This is the seller paying InvoxAI's OWN fees via InvoxAI's platform
/// gateway — NOT buyer money (hard rule). `currentPeriodEnd` is extended on each
/// paid order; status flips to PAST_DUE when it lapses.
///
/// Tenant isolation: every read/write is scoped by `tenantId` derived from the
/// authenticated session, never from request input. RLS: deny-anon lockdown
/// (platform/server-only via Prisma).
model Subscription {
  id               String             @id @default(uuid()) @db.Uuid
  tenantId         String             @unique @map("tenant_id") @db.Uuid
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId           String             @map("plan_id") @db.Uuid
  plan             Plan               @relation(fields: [planId], references: [id])
  status           SubscriptionStatus @default(PENDING)
  billingCycle     BillingCycle       @map("billing_cycle")
  currentPeriodEnd DateTime?          @map("current_period_end")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  @@map("subscriptions")
}

/// One checkout attempt against the platform gateway (C4). We create the
/// Razorpay order server-side and store it here BEFORE redirecting to checkout,
/// so the amount/plan/cycle are server-trusted (never taken from the client at
/// confirm time). `razorpayOrderId` is unique — the activation keyed on it is
/// idempotent, so a replayed webhook or a double client callback can't extend
/// the period twice. Amount is integer paise.
model PlatformOrder {
  id              String        @id @default(uuid()) @db.Uuid
  razorpayOrderId String        @unique @map("razorpay_order_id")
  tenantId        String        @map("tenant_id") @db.Uuid
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purpose         OrderPurpose  @default(SUBSCRIPTION)
  // Set only for SUBSCRIPTION orders; null for WALLET_TOPUP.
  planId          String?       @map("plan_id") @db.Uuid
  plan            Plan?         @relation(fields: [planId], references: [id])
  billingCycle    BillingCycle? @map("billing_cycle")
  // Set only for FEATURE orders (which paid feature this credit unlocks).
  featureKey      String?       @map("feature_key")
  amountPaise     Int           @map("amount_paise")
  status          OrderStatus   @default(CREATED)
  razorpayPaymentId String?     @map("razorpay_payment_id")
  paidAt          DateTime?     @map("paid_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("platform_orders")
}

/// A seller's prepaid wallet (C5). One per tenant. Holds ONLY the seller's own
/// money for InvoxAI's fees (commission, ₹149 AI-page, add-ons) — NEVER buyer
/// money (hard rule). `balancePaise` is the cached balance; it is only ever
/// mutated inside the same transaction that appends a WalletTransaction, so the
/// ledger and the balance never diverge. RLS: deny-anon lockdown.
model Wallet {
  id           String              @id @default(uuid()) @db.Uuid
  tenantId     String              @unique @map("tenant_id") @db.Uuid
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  balancePaise Int                 @default(0) @map("balance_paise")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  transactions WalletTransaction[]

  @@map("wallets")
}

/// Append-only wallet ledger (C5). Every credit/debit is one row carrying the
/// `balanceAfter` snapshot for auditability. `referenceId` is an idempotency key
/// (unique): a credit uses the platform order id, a debit uses the fee event id,
/// so a retried credit/debit can't double-apply. Null referenceId is allowed
/// (Postgres lets multiple NULLs coexist under a unique index).
model WalletTransaction {
  id            String             @id @default(uuid()) @db.Uuid
  walletId      String             @map("wallet_id") @db.Uuid
  wallet        Wallet             @relation(fields: [walletId], references: [id], onDelete: Cascade)
  tenantId      String             @map("tenant_id") @db.Uuid
  direction     WalletTxnDirection
  amountPaise   Int                @map("amount_paise")
  balanceAfter  Int                @map("balance_after")
  reason        String
  referenceType String?            @map("reference_type")
  referenceId   String?            @unique @map("reference_id")
  createdAt     DateTime           @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@map("wallet_transactions")
}

/// A seller's OWN payment gateway (C6). Buyer payments are created on THIS
/// account so funds settle seller-direct and NEVER pass through InvoxAI (RBI
/// hard rule).
///
/// SECURITY: `keyId` is not secret (it is the Basic-auth username and is exposed
/// to the browser by Checkout), so it is stored plaintext for display. The
/// `secretEnc` field is the API secret, stored ENCRYPTED (AES-256-GCM) — the
/// plaintext secret never lives in the DB and is never sent to the browser.
/// RLS: deny-anon lockdown; server (Prisma) only.
model SellerGateway {
  id          String          @id @default(uuid()) @db.Uuid
  tenantId    String          @unique @map("tenant_id") @db.Uuid
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider    GatewayProvider @default(RAZORPAY)
  keyId       String          @map("key_id") // e.g. rzp_test_… (NOT secret)
  secretEnc   String          @map("secret_enc") // AES-256-GCM ciphertext bundle
  mode        GatewayMode
  status      GatewayStatus   @default(CONNECTED)
  connectedAt DateTime        @default(now()) @map("connected_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@map("seller_gateways")
}

/// A seller's manual UPI payment method (alt rail to Razorpay). Buyers pay this
/// UPI ID directly and submit the transaction reference; the seller confirms.
/// One per tenant. deny-anon RLS; owner-scoped via Prisma (FK in migration).
model SellerUpi {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @unique @map("tenant_id") @db.Uuid
  upiId       String   @map("upi_id") // e.g. name@okhdfc
  displayName String?  @map("display_name") // optional payee name shown to buyers
  enabled     Boolean  @default(true)
  // Auto-confirm: when on, the moment the buyer submits a payment reference the
  // order is marked PAID + access granted + commission charged (no seller step).
  // `autoConfirmMaxPaise` caps it (orders above fall back to manual confirm; null
  // = no cap). `sessionTtlMinutes` is the QR/payment-session validity window.
  autoConfirm        Boolean @default(true) @map("auto_confirm")
  autoConfirmMaxPaise Int?   @map("auto_confirm_max_paise")
  sessionTtlMinutes  Int     @default(10) @map("session_ttl_minutes")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("seller_upi")
}

/// A seller-created payment page/link (C7). A buyer pays a fixed amount at
/// `username.invoxai.io/pay/<slug>`. `slug` is unique PER TENANT (each seller has
/// their own namespace). Amount is integer paise. RLS: deny-anon lockdown (the
/// public buyer page renders server-side via Prisma).
model PaymentPage {
  id          String         @id @default(uuid()) @db.Uuid
  tenantId    String         @map("tenant_id") @db.Uuid
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slug        String
  title       String
  description String?
  amountPaise Int            @map("amount_paise")
  // Product-parity fields: an image/banner, an optional compare-at (struck "was"
  // price), a gated access link revealed to the buyer on PAID (community/download),
  // and a kind tag. Coupons apply to amountPaise at checkout.
  imageUrl       String?     @map("image_url")
  compareAtPaise Int?        @map("compare_at_paise")
  accessUrl      String?     @map("access_url")
  kind           ProductKind @default(DIGITAL)
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  payments    BuyerPayment[]
  // Growth G1.6: the A/B test running on this page (at most one).
  experiment  PageExperiment?

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("payment_pages")
}

/// One buyer payment attempt against a payment page (C7). The Razorpay order is
/// created on the SELLER's gateway, so money settles seller-direct. We persist
/// the order BEFORE checkout so confirmation validates a server-trusted amount.
/// `razorpayOrderId` unique → the PAID transition is idempotent (atomic claim),
/// so a refreshed callback can't double-record or double-charge commission.
model BuyerPayment {
  id                String             @id @default(uuid()) @db.Uuid
  razorpayOrderId   String             @unique @map("razorpay_order_id")
  tenantId          String             @map("tenant_id") @db.Uuid
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // An order is placed against EITHER a payment page (C7) OR a store product
  // (Store slice 2). Exactly one of these is set; both stay nullable in the
  // schema and the app guarantees one. `itemTitle` snapshots the name at sale
  // time so order history survives the product/page being edited or removed.
  paymentPageId     String?            @map("payment_page_id") @db.Uuid
  paymentPage       PaymentPage?       @relation(fields: [paymentPageId], references: [id])
  productId         String?            @map("product_id") @db.Uuid
  product           Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)
  // Courses / LMS: set when this order is a course purchase. On PAID it grants an
  // Enrolment (in markBuyerPaymentPaid, claim-winner only). Mutually exclusive
  // with paymentPageId/productId/cart lines.
  courseId          String?            @map("course_id") @db.Uuid
  course            Course?            @relation(fields: [courseId], references: [id], onDelete: SetNull)
  // Phase 12: set when this order is a community purchase. On PAID it grants a
  // CommunityMembership (markBuyerPaymentPaid, claim-winner only).
  communityId       String?            @map("community_id") @db.Uuid
  community         Community?         @relation(fields: [communityId], references: [id], onDelete: SetNull)
  // Phase: set when this order is a workshop registration. On PAID it grants a
  // WorkshopRegistration (markBuyerPaymentPaid, claim-winner only). Mutually
  // exclusive with productId/courseId/communityId — same access-order pattern.
  workshopId        String?            @map("workshop_id") @db.Uuid
  workshop          Workshop?          @relation(fields: [workshopId], references: [id], onDelete: SetNull)
  // Phase: set when this order is a booking (1-on-1) for a specific slot. On PAID it
  // claims the slot + grants a Booking (markBuyerPaymentPaid). Mutually exclusive
  // with the other sellable FKs — same access-order pattern.
  bookingSlotId     String?            @map("booking_slot_id") @db.Uuid
  bookingSlot       BookingSlot?       @relation(fields: [bookingSlotId], references: [id], onDelete: SetNull)
  quantity          Int                @default(1)
  itemTitle         String?            @map("item_title")
  // `amountPaise` is the CHARGED total the buyer actually paid. When a coupon was
  // applied (Store slice 3 coupons) it is the POST-discount total, so InvoxAI
  // commission (computed off amountPaise in markBuyerPaymentPaid) lands on the
  // discounted total automatically. The subtotal is recoverable as
  // amountPaise + discountPaise. `couponCode` snapshots the code at sale time.
  amountPaise       Int                @map("amount_paise")
  couponId          String?            @map("coupon_id") @db.Uuid
  coupon            Coupon?            @relation(fields: [couponId], references: [id], onDelete: SetNull)
  couponCode        String?            @map("coupon_code")
  discountPaise     Int                @default(0) @map("discount_paise")
  status            BuyerPaymentStatus @default(CREATED)
  // Manual UPI (alt rail): method + the buyer-submitted UPI transaction ref. For
  // RAZORPAY orders these stay default/null; the auto-verify path is unchanged.
  paymentMethod     PaymentMethod      @default(RAZORPAY) @map("payment_method")
  upiRef            String?            @map("upi_ref")
  // Manual UPI auto-confirm session: `payAmountPaise` is the unique amount the
  // buyer is told to pay = amountPaise (true sale price) + a small nonce, so an
  // incoming UPI credit maps to exactly one order. NEVER the commission/receipt
  // base (that stays amountPaise). `expiresAt` is the payment-session TTL; an
  // unsubmitted (upiRef null) session past it is swept to EXPIRED. Both null for
  // Razorpay rows. A partial unique index enforces (tenant, payAmountPaise)
  // uniqueness among live PENDING UPI sessions (see migration).
  payAmountPaise    Int?               @map("pay_amount_paise")
  expiresAt         DateTime?          @map("expires_at")
  // C8: set when the buyer was logged in at checkout, to attribute the order.
  buyerProfileId    String?            @map("buyer_profile_id") @db.Uuid
  buyerEmail        String?            @map("buyer_email")
  buyerContact      String?            @map("buyer_contact")
  // Campaign attribution: UTM params captured on landing (cookie) and stamped at
  // checkout, so analytics can break revenue down by source/campaign. Nullable.
  utmSource         String?            @map("utm_source")
  utmMedium         String?            @map("utm_medium")
  utmCampaign       String?            @map("utm_campaign")
  utmContent        String?            @map("utm_content")
  utmTerm           String?            @map("utm_term")
  // Ad-click attribution: the click IDs captured on landing (cookie), stamped at
  // checkout. Used for ad-platform conversion matching (Meta CAPI / Google
  // enhanced conversions) + per-campaign reporting. All nullable.
  fbclid            String?            @map("fbclid")
  gclid             String?            @map("gclid")
  ttclid            String?            @map("ttclid")
  fbp               String?            @map("fbp")
  // Affiliates: when the buyer arrived via an affiliate link (?ref=CODE captured
  // to a cookie), the order is attributed to that affiliate. `affiliateCommissionPaise`
  // is the amount the SELLER owes the affiliate (computed off the post-discount
  // amountPaise × the affiliate's commissionBps at sale time) — it is a RECORDED
  // figure only; it does NOT change the buyer's charge or the InvoxAI commission.
  affiliateId       String?            @map("affiliate_id") @db.Uuid
  affiliate         Affiliate?         @relation(fields: [affiliateId], references: [id], onDelete: SetNull)
  affiliateCode     String?            @map("affiliate_code")
  affiliateCommissionPaise Int         @default(0) @map("affiliate_commission_paise")
  razorpayPaymentId String?            @map("razorpay_payment_id")
  paidAt            DateTime?          @map("paid_at")
  // C10: fulfillment tracking (seller-set, buyer-visible).
  fulfillmentStatus FulfillmentStatus  @default(NEW) @map("fulfillment_status")
  trackingNote      String?            @map("tracking_note")
  // Phase 1: cumulative amount refunded to the buyer (on the seller's gateway).
  refundedPaise     Int                @default(0) @map("refunded_paise")
  // Phase 1.2: set when the bank reversed this payment (chargeback). Admin-marked.
  chargebackAt      DateTime?          @map("chargeback_at")
  // Growth G1.2: when the abandoned-checkout recovery email was sent for this
  // started-but-unpaid order (null = not yet nudged). The sweep claims it atomically
  // (set where null) so two concurrent runs can't double-send. Stays null forever for
  // orders that pay promptly or were never eligible.
  recoveryEmailAt   DateTime?          @map("recovery_email_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  commission        CommissionCharge?
  refunds           Refund[]
  // Store slice 3: line items for a multi-item (cart) order. Empty for a
  // single-product quick-buy (which uses productId/quantity above) and for
  // payment-page orders. The order total `amountPaise` is still authoritative.
  orderItems        OrderItem[]
  // Courses / LMS: the enrolment this purchase granted (course orders only).
  enrolment         Enrolment?
  // Phase 12: the community membership this purchase granted (community orders).
  communityMembership CommunityMembership?
  // Phase: the workshop registration this purchase granted (workshop orders).
  workshopRegistration WorkshopRegistration?
  // Phase: the booking this purchase granted (1-on-1 orders).
  booking              Booking?
  // Growth G1.1 (OTO): when this order is a post-purchase one-time offer, it links
  // back to the parent order that triggered it + the Upsell it accepted. A partial
  // unique on (parentPaymentId, upsellId) makes acceptance idempotent — a buyer can
  // create at most ONE OTO order per (parent order, upsell), so a refreshed success
  // page can't spin up duplicate charges. Both null for every normal order (Postgres
  // allows many NULL/NULL rows under the unique index).
  parentPaymentId   String?            @map("parent_payment_id") @db.Uuid
  parentPayment     BuyerPayment?      @relation("OtoParent", fields: [parentPaymentId], references: [id], onDelete: SetNull)
  otoChildren       BuyerPayment[]     @relation("OtoParent")
  upsellId          String?            @map("upsell_id") @db.Uuid
  upsell            Upsell?            @relation(fields: [upsellId], references: [id], onDelete: SetNull)

  @@unique([parentPaymentId, upsellId])
  @@index([tenantId, createdAt])
  @@index([tenantId, buyerProfileId])
  @@index([affiliateId])
  @@index([upsellId])
  @@index([productId])
  @@index([courseId])
  @@index([communityId])
  @@index([couponId])
  @@index([paymentPageId])
  @@map("buyer_payments")
}

enum AffiliateStatus {
  ACTIVE
  PAUSED
}

/// A seller's affiliate/referral partner. Buyers who land via this affiliate's
/// link (?ref=CODE) get the order attributed to it; the seller owes the affiliate
/// `commissionBps` of each attributed PAID order's total (off-platform — InvoxAI
/// only records it). `clicks` is a lightweight landing counter. Codes are unique
/// per tenant so two sellers can both use "FRIEND10".
model Affiliate {
  id            String          @id @default(uuid()) @db.Uuid
  tenantId      String          @map("tenant_id") @db.Uuid
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code          String
  name          String
  email         String?
  commissionBps Int             @default(1000) @map("commission_bps")
  clicks        Int             @default(0)
  status        AffiliateStatus @default(ACTIVE)
  createdAt     DateTime        @default(now()) @map("created_at")
  buyerPayments BuyerPayment[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("affiliates")
}

/// Post-purchase one-time offer (OTO) — Growth slice G1.1. After a buyer completes
/// a purchase, the seller can pitch ONE more product at a one-click discount, charged
/// on the SELLER's OWN gateway (same money rail as any sale; InvoxAI commission from
/// the wallet — buyer money never touches InvoxAI). Order-BUMP (pre-purchase, shown at
/// checkout) is a SEPARATE mechanism — see Product.bumpEnabled — so this models only
/// the post-purchase OTO.
///
/// `offerProduct` is the product pitched. `triggerProductId` null = show after ANY
/// purchase; set = only after that specific product was bought. `discountBps` is an
/// OTO-only markdown off the offer product's price (0 = full price, 10000 = free —
/// clamped server-side at offer time). Part 2 wires the buyer success-page offer + the
/// idempotent one-click charge (a new BuyerPayment via the markBuyerPaymentPaid claim,
/// guarded by a unique consume token so a refresh can't double-charge). RLS: deny-anon.
model Upsell {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // The product pitched as the OTO. Deleting it removes the offer (Cascade).
  offerProductId   String   @map("offer_product_id") @db.Uuid
  offerProduct     Product  @relation("UpsellOffer", fields: [offerProductId], references: [id], onDelete: Cascade)
  // Optional gate: only show this OTO after the buyer bought this product. Null = any
  // purchase. Deleting the trigger product removes the gated OTO (Cascade).
  triggerProductId String?  @map("trigger_product_id") @db.Uuid
  triggerProduct   Product? @relation("UpsellTrigger", fields: [triggerProductId], references: [id], onDelete: Cascade)
  headline         String
  blurb            String?
  discountBps      Int      @default(0) @map("discount_bps")
  active           Boolean  @default(true)
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // OTO orders accepted against this upsell (Part 2 money path).
  buyerPayments    BuyerPayment[]

  @@index([tenantId, active])
  @@index([offerProductId])
  @@index([triggerProductId])
  @@map("upsells")
}

/// One line of a multi-item (cart) order — Store slice 3. A cart checkout
/// creates ONE BuyerPayment (the payment/commission/fulfillment record, on the
/// seller's gateway) plus one OrderItem per product. `unitPricePaise` and
/// `titleSnapshot` capture the price/name at sale time so order history is
/// immutable even if the product is later edited or deleted (productId then
/// nulls out via SetNull). Stock is decremented per line on the PAID claim.
/// RLS: deny-anon lockdown (read/written server-side via Prisma).
model OrderItem {
  id             String       @id @default(uuid()) @db.Uuid
  buyerPaymentId String       @map("buyer_payment_id") @db.Uuid
  buyerPayment   BuyerPayment @relation(fields: [buyerPaymentId], references: [id], onDelete: Cascade)
  productId      String?      @map("product_id") @db.Uuid
  product        Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)
  titleSnapshot  String       @map("title_snapshot")
  unitPricePaise Int          @map("unit_price_paise")
  quantity       Int
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([buyerPaymentId])
  @@index([productId])
  @@map("order_items")
}

/// Links a Supabase user (Profile) to a tenant as a BUYER (C8). One per
/// (tenant, profile). A person can be a buyer on many tenants and/or a seller —
/// these are independent. Created on first visit to a tenant's Buyer Corner.
/// Buyers see ONLY their own data, always scoped by this tenantId (hard rule).
/// RLS: deny-anon lockdown (server renders the corner via Prisma).
model BuyerAccount {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profileId String   @map("profile_id") @db.Uuid
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([tenantId, profileId])
  @@index([tenantId])
  @@map("buyer_accounts")
}

/// An AI-generated landing page (C9). Generated by Claude from the seller's
/// brief, charged ₹149 from the seller's wallet on success, and published at
/// `username.invoxai.io/<slug>`. `content` is the structured JSON Claude
/// returned (title/tagline/sections/CTA), rendered server-side into styled
/// markup — we never inject raw model HTML. `chargeRef` is the wallet-debit
/// idempotency key for the ₹149 charge. RLS: deny-anon lockdown (rendered
/// server-side via Prisma). `slug` unique per tenant; reserved labels
/// (pay/account/api/health) are rejected app-side so it can't shadow a route.
model AiPage {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slug        String
  title       String
  brief       String // the seller's prompt, kept for re-generation/audit
  content     Json // structured content Claude returned
  isPublished Boolean  @default(true) @map("is_published")
  // Null when generated within the plan's free allowance (no charge); the
  // feature-charge reference when it was paid (Feature Billing engine).
  chargeRef   String?  @unique @map("charge_ref")
  // Builder (multi-page): when set, this page belongs to a BuilderSite and appears in
  // its shared nav (navLabel/navOrder). Null = a standalone page (unchanged). Deleting
  // the site detaches the pages (SetNull), it never deletes them.
  siteId      String?      @map("site_id") @db.Uuid
  site        BuilderSite? @relation(fields: [siteId], references: [id], onDelete: SetNull)
  navLabel    String?      @map("nav_label")
  navOrder    Int          @default(0) @map("nav_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  versions    AiPageVersion[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([siteId])
  @@map("ai_pages")
}

/// A snapshot of an AI page's content on each save (AI builder version history).
/// Keeps the latest ~20 per page (pruned app-side). Restore copies a snapshot
/// back onto the page (itself snapshotted, so restore is non-destructive).
/// deny-anon RLS; tenant-scoped reads/writes via the seller editor.
model AiPageVersion {
  id        String   @id @default(uuid()) @db.Uuid
  aiPageId  String   @map("ai_page_id") @db.Uuid
  aiPage    AiPage   @relation(fields: [aiPageId], references: [id], onDelete: Cascade)
  tenantId  String   @map("tenant_id") @db.Uuid
  content   Json
  createdAt DateTime @default(now()) @map("created_at")

  @@index([aiPageId, createdAt])
  @@map("ai_page_versions")
}

/// A GST tax invoice for a charge a seller paid InvoxAI (Phase 1.3). One per
/// taxable event (`refType`+`refId` unique → idempotent issuance). `number` is a
/// gap-free per-financial-year sequence (see InvoiceCounter). Amounts are paise;
/// the charge total is treated as tax-INCLUSIVE and split into base + GST.
/// RLS: deny-anon lockdown.
model Invoice {
  id              String   @id @default(uuid()) @db.Uuid
  number          String   @unique
  tenantId        String   @map("tenant_id") @db.Uuid
  kind            String // e.g. "SUBSCRIPTION"
  refType         String   @map("ref_type")
  refId           String   @map("ref_id") @db.Uuid
  descriptionLine String   @map("description_line")
  basePaise       Int      @map("base_paise")
  taxPaise        Int      @map("tax_paise")
  totalPaise      Int      @map("total_paise")
  gstRateBps      Int      @map("gst_rate_bps")
  issuedAt        DateTime @default(now()) @map("issued_at")

  @@unique([refType, refId])
  @@index([tenantId, issuedAt])
  @@map("invoices")
}

/// Per-financial-year invoice number counter (gap-free sequence). `fy` is the
/// FY label (e.g. "2025-26"); `lastNumber` is incremented atomically per issue.
model InvoiceCounter {
  fy         String @id
  lastNumber Int    @default(0) @map("last_number")

  @@map("invoice_counters")
}

/// Audit trail of every mutating PLATFORM-ADMIN action (Phase 3): tenant
/// suspend/unsuspend and manual wallet credit/debit. Records who (adminEmail),
/// what (action), on whom (tenantId), how much (amountPaise), and why (detail).
/// Append-only; never edited. RLS: deny-anon lockdown.
model AdminAuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  adminEmail  String   @map("admin_email")
  action      String // e.g. tenant.suspend / tenant.unsuspend / wallet.credit / wallet.debit
  tenantId    String?  @map("tenant_id") @db.Uuid
  amountPaise Int?     @map("amount_paise")
  detail      String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@map("admin_audit_logs")
}

enum AbuseStatus {
  NEW
  REVIEWING
  ACTIONED
  DISMISSED
}

/// Phase 16: a public abuse/scam report against a tenant store. Filed anonymously
/// from the storefront (/report-abuse, host-resolved tenant) and triaged by admins,
/// who can then suspend the tenant / disable content via the existing admin tools.
/// `tenantId` is a denormalised scalar; the FK + deny-anon RLS are in the migration
/// (the report is INSERTED server-side via Prisma, never by the anon client). Review
/// actions are written to AdminAuditLog.
model AbuseReport {
  id            String      @id @default(uuid()) @db.Uuid
  tenantId      String      @map("tenant_id") @db.Uuid
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reason        String // category, e.g. "fraud" | "prohibited" | "offensive" | "spam" | "other"
  detail        String?
  reporterEmail String?     @map("reporter_email")
  pageUrl       String?     @map("page_url")
  status        AbuseStatus @default(NEW)
  adminNote     String?     @map("admin_note")
  reviewedBy    String?     @map("reviewed_by")
  reviewedAt    DateTime?   @map("reviewed_at")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@index([tenantId])
  @@map("abuse_reports")
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
}

enum RiskStatus {
  OPEN
  DISMISSED
  RESOLVED
}

/// Phase 16: an admin-facing risk signal derived from existing data (chargebacks,
/// open abuse reports, large uncollected commission). Generated/refreshed by
/// refreshRiskAlerts (idempotent, one row per tenant+type); admins dismiss them.
/// Read-only signal — NO buyer/money surface. deny-anon RLS.
model RiskAlert {
  id         String       @id @default(uuid()) @db.Uuid
  tenantId   String       @map("tenant_id") @db.Uuid
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type       String // "chargebacks" | "abuse_reports" | "commission_due"
  severity   RiskSeverity @default(MEDIUM)
  detail     String
  status     RiskStatus   @default(OPEN)
  reviewedBy String?      @map("reviewed_by")
  reviewedAt DateTime?    @map("reviewed_at")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  @@unique([tenantId, type])
  @@index([status])
  @@map("risk_alerts")
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

/// A file in the seller's media library (cloud storage). The object lives in the
/// PRIVATE downloads bucket under the tenant's `tenant/<id>/` key prefix; this row
/// is the catalog entry (name/size/type) + the source of truth for storage usage.
/// `key` is the opaque storage key (never a public URL — downloads go via a signed
/// URL minted server-side). RLS: deny-anon.
model FileAsset {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key         String   @unique
  name        String
  sizeBytes   Int      @map("size_bytes")
  contentType String   @map("content_type")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@map("file_assets")
}

enum BookingTypeStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// A 1-on-1 / consultation offering — SAME money rail as a workshop, but the buyer
/// books a specific time SLOT. `meetingUrl` (Zoom/Meet) is revealed only to a
/// confirmed booker. Buyers pay on the seller's gateway; the PAID order claims the
/// slot + grants a Booking (markBuyerPaymentPaid, claim-winner only). RLS: deny-anon.
model BookingType {
  id           String            @id @default(uuid()) @db.Uuid
  tenantId     String            @map("tenant_id") @db.Uuid
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slug         String
  title        String
  description  String?
  pricePaise   Int               @map("price_paise")
  compareAtPaise Int?            @map("compare_at_paise")
  imageUrl     String?           @map("image_url")
  meetingUrl   String?           @map("meeting_url")
  durationMins Int?              @map("duration_mins")
  status       BookingTypeStatus @default(DRAFT)
  sortOrder    Int               @default(0) @map("sort_order")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  slots    BookingSlot[]
  bookings Booking[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@map("booking_types")
}

/// One bookable time slot of a BookingType. status OPEN → BOOKED (claimed atomically
/// on PAID — see markBuyerPaymentPaid). A slot holds one booking.
model BookingSlot {
  id            String         @id @default(uuid()) @db.Uuid
  tenantId      String         @map("tenant_id") @db.Uuid
  bookingTypeId String         @map("booking_type_id") @db.Uuid
  bookingType   BookingType    @relation(fields: [bookingTypeId], references: [id], onDelete: Cascade)
  startsAt      DateTime       @map("starts_at")
  status        String         @default("OPEN") // OPEN | BOOKED
  createdAt     DateTime       @default(now()) @map("created_at")

  booking       Booking?
  buyerPayments BuyerPayment[]

  @@index([bookingTypeId, status])
  @@map("booking_slots")
}

/// A confirmed booking, granted on PAID (claim-winner only; buyerPaymentId unique →
/// no double-grant). Normally tied to a slot (unique); if the slot was taken in a
/// rare race, the booking is recorded slot-less with the desired `startsAt` so the
/// seller reschedules — a payment is NEVER lost.
model Booking {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookingTypeId  String        @map("booking_type_id") @db.Uuid
  bookingType    BookingType   @relation(fields: [bookingTypeId], references: [id], onDelete: Cascade)
  slotId         String?       @unique @map("slot_id") @db.Uuid
  slot           BookingSlot?  @relation(fields: [slotId], references: [id], onDelete: SetNull)
  startsAt       DateTime?     @map("starts_at")
  buyerProfileId String?       @map("buyer_profile_id") @db.Uuid
  buyerEmail     String?       @map("buyer_email")
  buyerPaymentId String?       @unique @map("buyer_payment_id") @db.Uuid
  buyerPayment   BuyerPayment? @relation(fields: [buyerPaymentId], references: [id], onDelete: SetNull)
  source         String        @default("paid")
  createdAt      DateTime      @default(now()) @map("created_at")

  @@index([tenantId, bookingTypeId])
  @@index([bookingTypeId, buyerProfileId])
  @@map("bookings")
}

enum WorkshopStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// A live workshop / session — the SAME money model as a community/course: sold on
/// the SELLER's gateway, and a PAID order grants a WorkshopRegistration (claim-
/// winner only, in markBuyerPaymentPaid). Adds scheduling (`scheduledAt`,
/// `durationMins`) and an optional `maxSeats` soft cap (checked best-effort at
/// checkout — see startWorkshopCheckout). `joinUrl` (Zoom/Meet) is revealed ONLY to
/// registrants in the account area, never on the public page. RLS: deny-anon.
model Workshop {
  id             String         @id @default(uuid()) @db.Uuid
  tenantId       String         @map("tenant_id") @db.Uuid
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slug           String
  title          String
  description    String?
  pricePaise     Int            @map("price_paise")
  compareAtPaise Int?           @map("compare_at_paise")
  imageUrl       String?        @map("image_url")
  joinUrl        String?        @map("join_url")
  scheduledAt    DateTime?      @map("scheduled_at")
  durationMins   Int?           @map("duration_mins")
  maxSeats       Int?           @map("max_seats")
  status         WorkshopStatus @default(DRAFT)
  sortOrder      Int            @default(0) @map("sort_order")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  registrations WorkshopRegistration[]
  buyerPayments BuyerPayment[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@map("workshops")
}

/// One buyer's registration in a workshop — granted on PAID (claim-winner only).
/// `buyerPaymentId` is unique so a webhook replay can't double-grant. Attributed by
/// profileId (logged in) OR buyerEmail (guest who later signs in with that email).
model WorkshopRegistration {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workshopId     String        @map("workshop_id") @db.Uuid
  workshop       Workshop      @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  buyerProfileId String?       @map("buyer_profile_id") @db.Uuid
  buyerEmail     String?       @map("buyer_email")
  buyerPaymentId String?       @unique @map("buyer_payment_id") @db.Uuid
  buyerPayment   BuyerPayment? @relation(fields: [buyerPaymentId], references: [id], onDelete: SetNull)
  source         String        @default("paid")
  createdAt      DateTime      @default(now()) @map("created_at")

  @@index([tenantId, workshopId])
  @@index([workshopId, buyerProfileId])
  @@map("workshop_registrations")
}

enum CommunityStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// Phase 12: a community / members space — the SAME money model as a course
/// (sold on the seller's own gateway; commission from the wallet; a PAID order
/// grants a CommunityMembership in markBuyerPaymentPaid, claim-winner only). A
/// free community (pricePaise 0) is joined directly (no payment). `accessUrl` is
/// the members-only external link (Telegram/Discord/WhatsApp/private). RLS:
/// deny-anon; published reads + member grants happen server-side via Prisma.
model Community {
  id             String          @id @default(uuid()) @db.Uuid
  tenantId       String          @map("tenant_id") @db.Uuid
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slug           String
  title          String
  description    String?
  pricePaise     Int             @map("price_paise") // 0 = free to join
  compareAtPaise Int?            @map("compare_at_paise")
  imageUrl       String?         @map("image_url")
  accessUrl      String?         @map("access_url") // members-only external link
  status         CommunityStatus @default(DRAFT)
  sortOrder      Int             @default(0) @map("sort_order")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  posts         CommunityPost[]
  memberships   CommunityMembership[]
  buyerPayments BuyerPayment[]
  messages      CommunityMessage[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@map("communities")
}

/// A seller announcement/post inside a community — shown only in the gated
/// members area. Simpler than a Lesson (no preview gating; everything here is
/// members-only).
model CommunityPost {
  id          String    @id @default(uuid()) @db.Uuid
  communityId String    @map("community_id") @db.Uuid
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  title       String
  body        String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([communityId])
  @@map("community_posts")
}

/// A buyer's membership in a community (mirrors Enrolment). PAID memberships are
/// created ONLY by the PAID claim winner in markBuyerPaymentPaid (buyerPaymentId
/// unique → a replay can't double-grant); free memberships are created directly
/// on join. Attribution by profileId (logged in) OR purchase/join email.
model CommunityMembership {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  communityId    String        @map("community_id") @db.Uuid
  community      Community     @relation(fields: [communityId], references: [id], onDelete: Cascade)
  buyerProfileId String?       @map("buyer_profile_id") @db.Uuid
  buyerEmail     String?       @map("buyer_email")
  buyerPaymentId String?       @unique @map("buyer_payment_id") @db.Uuid
  buyerPayment   BuyerPayment? @relation(fields: [buyerPaymentId], references: [id], onDelete: SetNull)
  source         String        @default("paid") // "paid" | "free"
  createdAt      DateTime      @default(now()) @map("created_at")

  @@index([tenantId, communityId])
  @@index([communityId, buyerProfileId])
  @@map("community_memberships")
}

/// Moderation state for a member discussion message. VISIBLE by default; the
/// seller (community owner) HIDES a message to remove it from the members view
/// without destroying it (audit-friendly), or hard-deletes it entirely.
enum CommunityMessageStatus {
  VISIBLE
  HIDDEN
}

/// Member-to-member discussion inside a community (distinct from CommunityPost,
/// which is seller-only announcements). Authored by a MEMBER (a buyer Profile
/// with a CommunityMembership — the gate is enforced in the server action, never
/// the anon client). One level of threading via `parentId` (a reply to a
/// top-level message). `authorName` is a display snapshot taken at post time
/// (buyers have no stored name). tenantId is denormalised for isolation + RLS.
/// RLS: deny-anon; reads/writes are server-side via Prisma after a membership
/// check. No money path.
model CommunityMessage {
  id             String                 @id @default(uuid()) @db.Uuid
  tenantId       String                 @map("tenant_id") @db.Uuid
  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  communityId    String                 @map("community_id") @db.Uuid
  community      Community              @relation(fields: [communityId], references: [id], onDelete: Cascade)
  buyerProfileId String                 @map("buyer_profile_id") @db.Uuid
  authorName     String                 @map("author_name")
  body           String
  parentId       String?                @map("parent_id") @db.Uuid
  parent         CommunityMessage?      @relation("CommunityThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies        CommunityMessage[]     @relation("CommunityThread")
  status         CommunityMessageStatus @default(VISIBLE)
  createdAt      DateTime               @default(now()) @map("created_at")

  @@index([communityId, status, createdAt])
  @@index([tenantId])
  @@index([parentId])
  @@map("community_messages")
}

/// Phase 16: a KYC / verification document a seller uploads to support their
/// verification submission (ID, business registration, address proof…). The file
/// lives in the PRIVATE downloads bucket under `tenant/<id>/kyc/`; `storageKey` is
/// the object key — NEVER public. It's revealed only via a short-lived signed URL,
/// server-side, to the owning seller or an admin reviewer. Verification status
/// itself stays denormalised on the Tenant; these are the supporting attachments.
/// RLS: deny-anon.
model KycDocument {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  docType    String   @map("doc_type") // identity | business | address | other
  fileName   String   @map("file_name")
  storageKey String   @map("storage_key") // PRIVATE object key; never exposed as a URL
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("kyc_documents")
}

/// Order fulfillment lifecycle (C10), set by the seller and shown to the buyer.
/// Digital sellers can jump straight to DELIVERED; CANCELLED is terminal.
enum FulfillmentStatus {
  NEW
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

/// InvoxAI's commission on one buyer payment (C7). One per buyer payment.
/// `status` is PAID once debited from the seller's wallet, or DUE while the
/// wallet can't cover it (settled on the next top-up). `bps` records the rate
/// applied for audit. This is seller wallet money — never buyer money.
model CommissionCharge {
  id             String           @id @default(uuid()) @db.Uuid
  buyerPaymentId String           @unique @map("buyer_payment_id") @db.Uuid
  buyerPayment   BuyerPayment     @relation(fields: [buyerPaymentId], references: [id], onDelete: Cascade)
  tenantId       String           @map("tenant_id") @db.Uuid
  amountPaise    Int              @map("amount_paise")
  bps            Int
  status         CommissionStatus @default(PAID)
  settledAt      DateTime?        @map("settled_at")
  createdAt      DateTime         @default(now()) @map("created_at")

  @@index([tenantId, status])
  @@map("commission_charges")
}

/// A refund issued to a buyer on the SELLER's gateway (Phase 1). InvoxAI does
/// not hold buyer money, so the refund happens in the seller's Razorpay; this
/// row records it and the proportional commission InvoxAI reversed back to the
/// seller (credited to their wallet if the commission was already collected, or
/// deducted from the amount still DUE). `razorpayRefundId` is unique → recording
/// is idempotent. Partial refunds accumulate via BuyerPayment.refundedPaise.
model Refund {
  id                      String       @id @default(uuid()) @db.Uuid
  razorpayRefundId        String       @unique @map("razorpay_refund_id")
  buyerPaymentId          String       @map("buyer_payment_id") @db.Uuid
  buyerPayment            BuyerPayment @relation(fields: [buyerPaymentId], references: [id], onDelete: Cascade)
  tenantId                String       @map("tenant_id") @db.Uuid
  amountPaise             Int          @map("amount_paise")
  commissionReversedPaise Int          @map("commission_reversed_paise")
  createdAt               DateTime     @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([buyerPaymentId])
  @@map("refunds")
}

enum DomainStatus {
  PENDING
  VERIFIED
}

/// A custom domain a seller connects to their tenant site (Custom domains, Phase
/// 15). The seller adds the domain (PENDING) + a TXT challenge token; once they
/// add the `_invoxai-challenge` TXT record and we confirm it, the domain becomes
/// VERIFIED and starts serving (Caddy on-demand TLS issues a cert via the
/// tls-allow ask endpoint, which only allows VERIFIED domains).
///
/// ISOLATION (critical): a host resolves to a tenant ONLY via a VERIFIED row, and
/// a partial unique index (see the migration) allows at most ONE VERIFIED row per
/// domain — so two tenants can never both serve the same host. The TXT token
/// proves the seller controls the DNS before we ever serve their tenant on it.
/// `@@unique([tenantId, domain])` stops a tenant adding the same domain twice.
/// RLS: deny-anon lockdown.
model TenantDomain {
  id          String       @id @default(uuid()) @db.Uuid
  tenantId    String       @map("tenant_id") @db.Uuid
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  domain      String // lowercased host, e.g. "shop.example.com"
  status      DomainStatus @default(PENDING)
  verifyToken String       @map("verify_token")
  verifiedAt  DateTime?    @map("verified_at")
  // Phase 15 (slice 4): the tenant's canonical/preferred public host. At most one
  // primary per tenant (partial unique index in the migration); only a VERIFIED
  // domain can be made primary. Used for canonical links (e.g. the buyer receipt's
  // "Visit store" URL) — host RESOLUTION is still by exact domain match, unaffected.
  isPrimary   Boolean      @default(false) @map("is_primary")
  createdAt   DateTime     @default(now()) @map("created_at")

  @@unique([tenantId, domain])
  @@index([domain])
  @@map("tenant_domains")
}

/// A seller-facing in-app notification (Notifications engine, slice 1). Created
/// as a best-effort side effect of events (a sale, a low wallet) AFTER the money
/// path commits — never inside a payment transaction, and only once per event
/// (the caller fires it only on a newly-PAID order, not on webhook replays).
/// `link` is a relative path in the seller app (e.g. "/orders"). `readAt` set
/// when the seller has seen it. Tenant-scoped; RLS: deny-anon lockdown. Email +
/// buyer notifications come in a later slice.
model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      String // e.g. "sale", "wallet_low"
  title     String
  body      String?
  link      String?
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([tenantId, readAt])
  @@map("notifications")
}

/// Phase 14 (slice 2): an append-only record of every outbound notification we
/// attempt on an EXTERNAL channel (email now; SMS/WhatsApp later). Written AFTER
/// the money path as a best-effort side effect, so a logging failure never
/// affects a payment. `status` is "sent" | "failed" | "skipped" ("skipped" =
/// no provider key configured). `tenantId` is a denormalised scalar (no Prisma
/// relation); the FK + deny-anon RLS are added in the migration SQL, the same
/// pattern as SellerUpi. Read server-side via Prisma.
model NotificationLog {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  channel           String   @default("email")
  eventType         String   @map("event_type")
  recipient         String
  subject           String?
  status            String
  providerMessageId String?  @map("provider_message_id")
  error             String?
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@map("notification_logs")
}

/// Phase 14 (slice 3): an admin-editable copy override for a notification event +
/// channel. Platform-GLOBAL (no tenant) — set in the admin app behind requireAdmin
/// (writes an AdminAuditLog). When no row exists for an event, the send path falls
/// back to the code catalog's default subject/body (@invoxai/utils/notifications).
/// Only subject + body are editable; the layout chrome stays in code. deny-anon RLS.
model NotificationTemplate {
  id        String   @id @default(uuid()) @db.Uuid
  eventKey  String   @map("event_key")
  channel   String   @default("email")
  subject   String
  body      String
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([eventKey, channel])
  @@map("notification_templates")
}

/// Phase 14 (slice 3): a per-tenant on/off toggle for a notification event +
/// channel. No row = enabled (the default). Sellers manage these on their
/// dashboard; the send path skips an event whose preference is disabled. Scalar
/// tenant_id + SQL FK + deny-anon RLS (SellerUpi pattern).
model NotificationPreference {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  eventKey  String   @map("event_key")
  channel   String   @default("email")
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, eventKey, channel])
  @@map("notification_preferences")
}

/// Raw idempotency + audit log of every Razorpay webhook we accept. `eventId`
/// is Razorpay's event id with a UNIQUE constraint — the webhook records the
/// event first and a duplicate delivery trips the constraint, so the handler
/// no-ops instead of activating twice. Never trusted until its signature is
/// verified upstream.
model PaymentEvent {
  id        String   @id @default(uuid()) @db.Uuid
  eventId   String   @unique @map("event_id")
  type      String
  tenantId  String?  @map("tenant_id") @db.Uuid
  payload   Json
  // Phase 1.5: processing state for retry-safety. Null processedAt = not yet
  // successfully handled, so a redelivery should reprocess (handler is idempotent).
  processedAt DateTime? @map("processed_at")
  attempts    Int       @default(0)
  lastError   String?   @map("last_error")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([processedAt])
  @@map("payment_events")
}

/// Growth G1.3 — what enrols a contact into an EmailSequence. PURCHASE = a buyer
/// completing a paid order (optionally gated to one product); LEAD = a lead-form
/// submission; MANUAL = the seller adds a contact by hand. (SIGNUP can be added as a
/// value later.) The enrol hooks live in the existing PAID / lead-submit paths (Part 2).
enum SequenceTrigger {
  PURCHASE
  LEAD
  MANUAL
}

/// Channel a sequence step sends on. EMAIL now (reuses the notification email stack +
/// RESEND env-gate); WHATSAPP later via a channel adapter.
enum SequenceChannel {
  EMAIL
}

/// Lifecycle of one contact's run through a sequence. ACTIVE = steps remaining;
/// DONE = all steps sent; CANCELLED = stopped (seller paused / contact opted out).
enum EnrollmentStatus {
  ACTIVE
  DONE
  CANCELLED
}

/// A seller's automated drip sequence (Growth G1.3). A trigger event enrols a
/// contact (by email — the CRM has no contacts table, contacts are derived), and a
/// scheduled worker advances each enrolment through the ordered steps by their delay,
/// sending on the step's channel. Carries NO money. Reuses the notification email
/// stack (admin templates not involved — copy lives on the step). RLS: deny-anon.
model EmailSequence {
  id               String          @id @default(uuid()) @db.Uuid
  tenantId         String          @map("tenant_id") @db.Uuid
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String
  trigger          SequenceTrigger
  // PURCHASE only: optionally limit enrolment to buyers of this product. Null = any.
  triggerProductId String?         @map("trigger_product_id") @db.Uuid
  triggerProduct   Product?        @relation(fields: [triggerProductId], references: [id], onDelete: SetNull)
  active           Boolean         @default(true)
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  steps       SequenceStep[]
  enrollments SequenceEnrollment[]

  @@index([tenantId, active])
  @@index([trigger, active])
  @@index([triggerProductId])
  @@map("email_sequences")
}

/// One step in a sequence. `delayHours` is the wait BEFORE this step fires, measured
/// from the previous step's send (or from enrolment for the first step). `sortOrder`
/// is the 0-based position. `body` is the message; `subject` is used for EMAIL.
model SequenceStep {
  id         String          @id @default(uuid()) @db.Uuid
  sequenceId String          @map("sequence_id") @db.Uuid
  sequence   EmailSequence   @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  sortOrder  Int             @map("sort_order")
  delayHours Int             @map("delay_hours")
  channel    SequenceChannel @default(EMAIL)
  subject    String?
  body       String
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  @@index([sequenceId, sortOrder])
  @@map("sequence_steps")
}

/// One contact's run through a sequence (Part 2 worker writes/advances these). Enrol
/// is idempotent per (sequence, email) so a repeated trigger can't double-enrol.
/// `currentStep` is the next step index to send; `nextRunAt` is when it's due. The
/// worker's hot query is (status=ACTIVE, nextRunAt<=now). tenantId denormalised for
/// scoped seller stats. RLS: deny-anon.
model SequenceEnrollment {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String           @map("tenant_id") @db.Uuid
  sequenceId  String           @map("sequence_id") @db.Uuid
  sequence    EmailSequence    @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  email       String // lowercased enrolled contact
  currentStep Int              @default(0) @map("current_step")
  nextRunAt   DateTime         @map("next_run_at")
  status      EnrollmentStatus @default(ACTIVE)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@unique([sequenceId, email])
  @@index([status, nextRunAt])
  @@index([tenantId])
  @@map("sequence_enrollments")
}

/// Phase 14 — email Broadcasts (one-off blast to a segment of contacts). A
/// broadcast is composed as a DRAFT, then "sent" → it SNAPSHOTS its recipient list
/// (one BroadcastRecipient row per contact) and goes QUEUED. A scheduled worker
/// (/api/cron/broadcasts) sweeps PENDING recipients, claims each atomically (so two
/// runs can't double-send), sends via the env-gated email channel, and finalises the
/// broadcast to SENT. Contacts are derived (no contacts table), so the snapshot is
/// the durable record of who a given broadcast went to. RLS: deny-anon.
model Broadcast {
  id             String               @id @default(uuid()) @db.Uuid
  tenantId       String               @map("tenant_id") @db.Uuid
  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String // internal label for the seller's list
  subject        String
  body           String // plain text (line breaks preserved); rendered to safe HTML
  segment        String               @default("ALL") // ALL | CUSTOMERS | LEADS
  status         String               @default("DRAFT") // DRAFT | QUEUED | SENDING | SENT | CANCELLED
  recipientCount Int                  @default(0) @map("recipient_count")
  sentCount      Int                  @default(0) @map("sent_count")
  failedCount    Int                  @default(0) @map("failed_count")
  queuedAt       DateTime?            @map("queued_at")
  sentAt         DateTime?            @map("sent_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  recipients BroadcastRecipient[]

  @@index([tenantId, createdAt])
  @@index([status])
  @@map("broadcasts")
}

/// One recipient of a broadcast — a frozen snapshot of a contact at send time.
/// Unique per (broadcast, email) so re-queuing/concurrent sweeps can't duplicate.
/// status: PENDING → SENDING (claimed) → SENT|FAILED (SKIPPED when env-gated off).
model BroadcastRecipient {
  id                String    @id @default(uuid()) @db.Uuid
  broadcastId       String    @map("broadcast_id") @db.Uuid
  broadcast         Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  email             String // lowercased recipient
  name              String?
  status            String    @default("PENDING") // PENDING | SENDING | SENT | FAILED | SKIPPED
  providerMessageId String?   @map("provider_message_id")
  error             String?
  sentAt            DateTime? @map("sent_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@unique([broadcastId, email])
  @@index([status])
  @@index([broadcastId])
  @@map("broadcast_recipients")
}

enum ExperimentStatus {
  RUNNING
  STOPPED
}

/// Growth G1.6 — an A/B test on a payment page. Variant A is the page's own title +
/// description; variant B overrides them. A visitor is 50/50 bucketed by a cookie and
/// shown one variant; views + conversions are tallied per variant (counters bumped by
/// the public /api/exp beacon, advisory like page-views — not a money surface). The
/// seller compares conversion rates and can stop the test / apply the winner's copy.
/// One experiment per page (paymentPageId unique). RLS: deny-anon.
model PageExperiment {
  id                  String           @id @default(uuid()) @db.Uuid
  tenantId            String           @map("tenant_id") @db.Uuid
  tenant              Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paymentPageId       String           @unique @map("payment_page_id") @db.Uuid
  paymentPage         PaymentPage      @relation(fields: [paymentPageId], references: [id], onDelete: Cascade)
  variantBTitle       String           @map("variant_b_title")
  variantBDescription String?          @map("variant_b_description")
  status              ExperimentStatus @default(RUNNING)
  aViews              Int              @default(0) @map("a_views")
  bViews              Int              @default(0) @map("b_views")
  aConversions        Int              @default(0) @map("a_conversions")
  bConversions        Int              @default(0) @map("b_conversions")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("page_experiments")
}

/// Lifecycle of a buyer support ticket. OPEN = awaiting the seller; ANSWERED = the
/// seller replied, awaiting the buyer; CLOSED = resolved (either side / seller).
enum SupportTicketStatus {
  OPEN
  ANSWERED
  CLOSED
}

enum SupportSender {
  BUYER
  SELLER
}

/// Ops — a buyer↔seller support thread, scoped to one tenant. Opened by a buyer from
/// the Buyer Corner; the seller answers from their dashboard inbox. The buyer is
/// attributed by `buyerProfileId` when logged in, plus `buyerEmail` (always set) so
/// access can be checked by either. No money path. RLS: deny-anon (reads/writes are
/// server-side after the buyer-session / seller-tenant gate).
model SupportTicket {
  id             String              @id @default(uuid()) @db.Uuid
  tenantId       String              @map("tenant_id") @db.Uuid
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  buyerProfileId String?             @map("buyer_profile_id") @db.Uuid
  buyerEmail     String              @map("buyer_email")
  subject        String
  status         SupportTicketStatus @default(OPEN)
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  messages SupportMessage[]

  @@index([tenantId, status, updatedAt])
  @@index([buyerProfileId])
  @@map("support_tickets")
}

/// One message in a support thread (buyer or seller). `sender` records who wrote it;
/// the thread is ordered by createdAt. Append-only.
model SupportMessage {
  id        String        @id @default(uuid()) @db.Uuid
  ticketId  String        @map("ticket_id") @db.Uuid
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender    SupportSender
  body      String
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([ticketId, createdAt])
  @@map("support_messages")
}

/// Builder — a multi-page site grouping several AiPages under a shared top nav. Each
/// page keeps its own slug + public URL (username.invoxai.io/<slug>); the site just
/// links siblings together (navLabel/navOrder) so a visitor can move between them. A
/// page with siteId null is standalone (unchanged). Deleting a site detaches its pages
/// (AiPage.siteId → null), never deletes them. RLS: deny-anon.
model BuilderSite {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  pages AiPage[]

  @@index([tenantId])
  @@map("builder_sites")
}

/// Admin-authored starter templates for the AI builder (Builder Part 3 —
/// templates marketplace). A GLOBAL catalog (NOT tenant-scoped): platform admins
/// author them; every seller can pick one. Applying a FREE template just copies
/// `content` block JSON into a new AiPage at no cost (like the static built-ins).
/// A PREMIUM template runs the Feature Billing engine (featureKey
/// "builder_template") before the page is created — the same charge path as a
/// paid AI generation. `content` is opaque block JSON re-validated through
/// normalizeToBlocks at apply time, so the render trust boundary still holds.
model BuilderTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  category    String // "landing" | "store" | "coaching" | "event" | ...
  description String
  themePreset String   @map("theme_preset") // drives the gallery mini-preview
  isPremium   Boolean  @default(false) @map("is_premium")
  isPublished Boolean  @default(true) @map("is_published")
  sortOrder   Int      @default(0) @map("sort_order")
  content     Json // BuilderContent block JSON (validated on apply)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isPublished, category, sortOrder])
  @@map("builder_templates")
}
