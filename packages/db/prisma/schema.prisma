// InvoxAI database schema.
//
// Runtime (Prisma Client) connects via the pooled DATABASE_URL (PgBouncer,
// port 6543). Migrations (Prisma CLI) use the direct DIRECT_URL (port 5432) —
// migrations hang on the pooler, so `directUrl` is required here.
//
// IMPORTANT (security): Prisma connects as the Postgres owner role and so
// BYPASSES Row Level Security. Tenant isolation is therefore enforced in
// application code (every tenant query scoped by ownerId/tenantId). RLS is
// enabled on every table as defense-in-depth for the Supabase anon/browser
// path. See the RLS migration that accompanies these models.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// App-level mirror of a Supabase Auth user (id == auth.users.id).
/// Created on first sign-in. A seller owns exactly one Tenant (C2); buyers
/// (C8) will also be Profiles but scoped per-tenant via a separate relation.
model Profile {
  id        String   @id @db.Uuid // = auth.users.id
  email     String?
  fullName  String?  @map("full_name")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// The tenant this profile owns as a seller (nullable until onboarding).
  ownedTenant Tenant?

  @@map("profiles")
}

/// A seller's site: username.invoxai.io. One tenant per owner for the MVP
/// (ownerId is unique). `username` is the subdomain label and is globally unique.
model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  username  String   @unique // lowercase subdomain label, validated app-side
  name      String?
  ownerId   String   @unique @db.Uuid
  owner     Profile  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([username])
  @@map("tenants")

  // C4: a tenant has at most one platform subscription, and many checkout orders.
  subscription Subscription?
  orders       PlatformOrder[]
}

/// C4 subscription lifecycle. PENDING = order created, not yet paid; ACTIVE =
/// paid and within the period; PAST_DUE = period lapsed without renewal;
/// CANCELED = explicitly ended.
enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum OrderStatus {
  CREATED
  PAID
  FAILED
}

/// A platform subscription tier a seller can subscribe to (used from C4).
///
/// MONEY: all amounts are stored as INTEGER paise (₹1 = 100 paise) — never
/// floats — to avoid rounding errors. Commission is stored as INTEGER basis
/// points (`commissionBps`): 250 = 2.50%, 10000 = 100%. Code references the
/// stable `key`, never the price, so admins can re-price without code changes
/// (hard rule: all pricing/limits/commission come from the DB, admin-editable).
///
/// Plans are never hard-deleted (a seller may be subscribed); `isActive=false`
/// retires a plan instead. RLS is enabled with NO policy → the anon/browser
/// path is denied entirely; only server code (Prisma, owner role) reads/writes.
model Plan {
  id            String   @id @default(uuid()) @db.Uuid
  key           String   @unique // stable slug referenced by code, e.g. "starter"
  name          String
  description   String?
  priceMonthly  Int      @default(0) @map("price_monthly") // paise
  priceYearly   Int      @default(0) @map("price_yearly") // paise
  commissionBps Int      @default(0) @map("commission_bps") // basis points
  maxProducts   Int?     @map("max_products") // null = unlimited
  maxAiPages    Int?     @map("max_ai_pages") // null = unlimited
  isActive      Boolean  @default(true) @map("is_active")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]
  orders        PlatformOrder[]

  @@index([isActive, sortOrder])
  @@map("plans")
}

/// Platform-wide pricing knobs as key/value, admin-editable (e.g. the
/// `ai_page_price` ₹149 fee). `valuePaise` is INTEGER paise, as above. Kept
/// separate from Plan because these are global, not per-tier. RLS: same
/// deny-anon lockdown as Plan.
model PricingSetting {
  key        String   @id // stable code key, e.g. "ai_page_price"
  label      String // human-readable description shown in the admin editor
  valuePaise Int      @map("value_paise")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("pricing_settings")
}

/// A seller's platform subscription (C4). Exactly one per tenant (`tenantId`
/// unique). This is the seller paying InvoxAI's OWN fees via InvoxAI's platform
/// gateway — NOT buyer money (hard rule). `currentPeriodEnd` is extended on each
/// paid order; status flips to PAST_DUE when it lapses.
///
/// Tenant isolation: every read/write is scoped by `tenantId` derived from the
/// authenticated session, never from request input. RLS: deny-anon lockdown
/// (platform/server-only via Prisma).
model Subscription {
  id               String             @id @default(uuid()) @db.Uuid
  tenantId         String             @unique @map("tenant_id") @db.Uuid
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId           String             @map("plan_id") @db.Uuid
  plan             Plan               @relation(fields: [planId], references: [id])
  status           SubscriptionStatus @default(PENDING)
  billingCycle     BillingCycle       @map("billing_cycle")
  currentPeriodEnd DateTime?          @map("current_period_end")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  @@map("subscriptions")
}

/// One checkout attempt against the platform gateway (C4). We create the
/// Razorpay order server-side and store it here BEFORE redirecting to checkout,
/// so the amount/plan/cycle are server-trusted (never taken from the client at
/// confirm time). `razorpayOrderId` is unique — the activation keyed on it is
/// idempotent, so a replayed webhook or a double client callback can't extend
/// the period twice. Amount is integer paise.
model PlatformOrder {
  id              String       @id @default(uuid()) @db.Uuid
  razorpayOrderId String       @unique @map("razorpay_order_id")
  tenantId        String       @map("tenant_id") @db.Uuid
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId          String       @map("plan_id") @db.Uuid
  plan            Plan         @relation(fields: [planId], references: [id])
  billingCycle    BillingCycle @map("billing_cycle")
  amountPaise     Int          @map("amount_paise")
  status          OrderStatus  @default(CREATED)
  razorpayPaymentId String?    @map("razorpay_payment_id")
  paidAt          DateTime?    @map("paid_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("platform_orders")
}

/// Raw idempotency + audit log of every Razorpay webhook we accept. `eventId`
/// is Razorpay's event id with a UNIQUE constraint — the webhook records the
/// event first and a duplicate delivery trips the constraint, so the handler
/// no-ops instead of activating twice. Never trusted until its signature is
/// verified upstream.
model PaymentEvent {
  id        String   @id @default(uuid()) @db.Uuid
  eventId   String   @unique @map("event_id")
  type      String
  tenantId  String?  @map("tenant_id") @db.Uuid
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")

  @@map("payment_events")
}
