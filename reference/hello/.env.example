# =========================================================================
# InvoxAI — example environment
# Fill in real values in .env.local (gitignored).
# =========================================================================

# Supabase ----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Razorpay ----------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=YOUR_RAZORPAY_WEBHOOK_SECRET
# RazorpayX virtual account number used as source of payouts
RAZORPAY_CURRENT_ACCOUNT=YOUR_RAZORPAYX_ACCOUNT_NUMBER

# Cashfree Payouts (fallback gateway) -------------------------------------
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=
# https://payout-api.cashfree.com (prod) or https://payout-gamma.cashfree.com (test)
CASHFREE_BASE_URL=https://payout-api.cashfree.com

# App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://app.invoxai.io

# Telegram Platform (MTProto User API + platform bot) ---------------------
# Platform-level creds shared by ALL users. Power the Cosmofeed-style flow:
# phone-OTP login (GramJS) -> list channels -> auto-add bot -> monetize.
#   API_ID / API_HASH: create an app at https://my.telegram.org/apps
#   BOT_*: the InvoxAI platform bot from @BotFather (added as admin to channels)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_BOT_ID=

# Transactional email (Resend) --------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=InvoxAI <hello@invoxai.io>

# Cron auth ---------------------------------------------------------------
# Random string. The /api/cron/* endpoints require this in x-cron-secret.
CRON_SECRET=YOUR_RANDOM_CRON_SECRET

# OTO (one-time offer) cookie signing key ---------------------------------
# 32+ char random string used to HMAC-sign post-purchase OTO redirects.
OTO_SECRET=YOUR_RANDOM_OTO_SECRET

# KYC provider (Surepass) -------------------------------------------------
SUREPASS_TOKEN=YOUR_SUREPASS_BEARER_TOKEN
# Optional override; default https://kyc-api.surepass.io
SUREPASS_BASE_URL=

# Transactional SMS / WhatsApp (Twilio) -----------------------------------
# From https://console.twilio.com (top-right)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
# SMS sender — your bought Twilio number in E.164
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# WhatsApp sender — sandbox default is whatsapp:+14155238886.
# After WhatsApp Sender approval, replace with whatsapp:+<your_business_number>
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Optional per-template Content SIDs — set after Meta approves the template
# in Twilio Content Builder. Until set, sendWhatsApp uses a built-in
# freeform fallback body (works in sandbox + 24h conversation window).
# TWILIO_TEMPLATE_NEW_SALE=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_TEMPLATE_PAYMENT_FAILED=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_TEMPLATE_NEW_LEAD=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_TEMPLATE_PAYOUT_DONE=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_TEMPLATE_KYC_UPDATE=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_TEMPLATE_PAYOUT_INITIATED=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_TEMPLATE_SUBSCRIPTION_RENEWAL=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_TEMPLATE_RECOVERY_CART=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DEPRECATED — MSG91 (kept here so reverting is a one-line swap) -----------
# MSG91_AUTH_KEY=YOUR_MSG91_AUTH_KEY
# MSG91_WA_FROM=
# MSG91_WA_NAMESPACE=
# MSG91_SMS_SENDER=INVOXAI
# MSG91_SMS_TEMPLATE_ID=

# Secret used to salt OTP hashes before they hit the DB
OTP_HASH_SALT=change_me_to_a_long_random_string

# Queues / cache ----------------------------------------------------------
REDIS_URL=redis://localhost:6379

# Platform economics ------------------------------------------------------
PLATFORM_COMMISSION_PERCENT=5

# Buyer portal (/account) -------------------------------------------------
# Secrets for the passwordless buyer portal. Both must be >=16 chars in prod.
BUYER_OTP_SALT=change_me_to_a_long_random_string
BUYER_PORTAL_SECRET=change_me_to_a_long_random_string

# Buyer Google login ------------------------------------------------------
# Create an OAuth 2.0 Client (type: Web application) in Google Cloud Console.
# Authorized redirect URI must EXACTLY equal <BUYER_OAUTH_BASE_URL>/api/buyer/google/callback
#   e.g. https://invoxai.io/api/buyer/google/callback
# Leave the client id/secret empty to hide the "Continue with Google" button.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Single central host Google redirects back to. Defaults to https://<platform root>.
BUYER_OAUTH_BASE_URL=https://invoxai.io

# AI website generator (Anthropic Claude) ---------------------------------
# Powers /dashboard/builder/ai. CAN ALSO be set from Admin → Integrations
# (stored encrypted), which takes precedence over these env vars.
# Option A — API key from https://console.anthropic.com (sk-ant-api…):
ANTHROPIC_API_KEY=
# Option B — account auth token (sk-ant-oat…) via `claude setup-token`, to bill
# your normal Claude account instead of a separate API key:
ANTHROPIC_AUTH_TOKEN=
