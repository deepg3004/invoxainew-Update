# env — never commit anything except .env.example.
# .env.production is on the VPS, NOT in the repo. The deploy.sh script
# uses `git reset --hard` so any accidentally-tracked .env.production
# would be wiped on the next deploy (we learned this the hard way).
.env
.env.local
.env.development.local
.env.test.local
.env.production
.env.production.local
.env.production.bak
.env*.bak
# Catch-all for any .env.production variant (snapshots, dated backups, etc.) —
# these are copies of the live secrets and must NEVER be committed.
.env.production.*
!.env.example

# vercel
.vercel

